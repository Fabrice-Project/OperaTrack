# ──────────────────────────────────────────────────────────────────────────────
# OpéraTrack — Variables d'environnement
# Copier ce fichier en server/.env pour le développement local
# En production, ces variables sont configurées dans le tableau de bord Vercel
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://[PROJET_ID].supabase.co
SUPABASE_ANON_KEY=[CLE_ANON_SUPABASE]
SUPABASE_SERVICE_ROLE_KEY=[CLE_SERVICE_ROLE_SUPABASE]

# ── CORS (URL du frontend en développement) ───────────────────────────────────
# En production Vercel, les requêtes sont same-origin — non nécessaire
CLIENT_URL=http://localhost:5173

# ── Serveur local ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
